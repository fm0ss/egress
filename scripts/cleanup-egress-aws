#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "usage: $0 <aws-profile> [home-region]" >&2
  exit 1
fi

PROFILE="$1"
HOME_REGION="${2:-us-east-1}"
AWS_BIN="${AWS_BIN:-aws}"

if ! command -v "$AWS_BIN" >/dev/null 2>&1; then
  echo "aws cli not found" >&2
  exit 1
fi

aws_cmd() {
  AWS_PAGER="" "$AWS_BIN" --no-cli-pager "$@"
}

echo "Using profile: $PROFILE"
echo "Discovering regions..."
mapfile -t REGIONS < <(aws_cmd ec2 describe-regions \
  --profile "$PROFILE" \
  --region "$HOME_REGION" \
  --query 'Regions[].RegionName' \
  --output text | tr '\t' '\n' | sed '/^$/d')

if [[ ${#REGIONS[@]} -eq 0 ]]; then
  echo "No regions returned for profile $PROFILE" >&2
  exit 1
fi

for region in "${REGIONS[@]}"; do
  echo
  echo "== Region: $region =="

  mapfile -t INSTANCE_IDS < <(aws_cmd ec2 describe-instances \
    --profile "$PROFILE" \
    --region "$region" \
    --filters \
      "Name=tag:EgressMode,Values=*" \
      "Name=instance-state-name,Values=pending,running,stopping,stopped" \
    --query 'Reservations[].Instances[].InstanceId' \
    --output text | tr '\t' '\n' | sed '/^$/d')

  if [[ ${#INSTANCE_IDS[@]} -gt 0 ]]; then
    echo "Terminating instances: ${INSTANCE_IDS[*]}"
    aws_cmd ec2 terminate-instances \
      --profile "$PROFILE" \
      --region "$region" \
      --instance-ids "${INSTANCE_IDS[@]}" \
      >/dev/null

    aws_cmd ec2 wait instance-terminated \
      --profile "$PROFILE" \
      --region "$region" \
      --instance-ids "${INSTANCE_IDS[@]}"
  else
    echo "No app-tagged gateway instances found"
  fi

  mapfile -t ALLOC_IDS < <(aws_cmd ec2 describe-addresses \
    --profile "$PROFILE" \
    --region "$region" \
    --query 'Addresses[?starts_with(Tags[?Key==`Name`].Value|[0], `egress-`) || AssociationId==null].AllocationId' \
    --output text | tr '\t' '\n' | sed '/^$/d')

  if [[ ${#ALLOC_IDS[@]} -gt 0 ]]; then
    for alloc in "${ALLOC_IDS[@]}"; do
      if [[ -n "$alloc" && "$alloc" != "None" ]]; then
        echo "Releasing EIP: $alloc"
        aws_cmd ec2 release-address \
          --profile "$PROFILE" \
          --region "$region" \
          --allocation-id "$alloc" \
          >/dev/null || true
      fi
    done
  else
    echo "No matching EIPs to release"
  fi

  mapfile -t SG_IDS < <(aws_cmd ec2 describe-security-groups \
    --profile "$PROFILE" \
    --region "$region" \
    --filters "Name=group-name,Values=egress-gateway-*" \
    --query 'SecurityGroups[].GroupId' \
    --output text | tr '\t' '\n' | sed '/^$/d')

  if [[ ${#SG_IDS[@]} -gt 0 ]]; then
    for sg in "${SG_IDS[@]}"; do
      if [[ -n "$sg" ]]; then
        echo "Deleting security group: $sg"
        aws_cmd ec2 delete-security-group \
          --profile "$PROFILE" \
          --region "$region" \
          --group-id "$sg" \
          >/dev/null || true
      fi
    done
  else
    echo "No matching security groups to delete"
  fi
done

echo
echo "Cleanup complete."
